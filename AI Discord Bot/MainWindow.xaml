<Window x:Class="AI_Discord_Bot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AI_Discord_Bot"
        xmlns:vm="clr-namespace:AI_Discord_Bot.ViewModels"
        Title="AI Discord Bot — Server Moderation Assistant"
        Height="640" Width="960" MinHeight="500" MinWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="4,4,4,0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Padding" Value="12,6"/>
                    <Setter Property="FontSize" Value="13"/>
                </Style>
            </TabControl.Resources>

            <!-- Log Tab -->
            <TabItem Header="Log">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <CheckBox Content="Auto-scroll" IsChecked="{Binding AutoScrollLog}"
                                  VerticalAlignment="Center"/>
                    </StackPanel>
                    <RichTextBox x:Name="LogRichTextBox" Grid.Row="1"
                                 IsReadOnly="True"
                                 FontFamily="Consolas" FontSize="12"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 BorderThickness="0"
                                 Padding="4">
                        <RichTextBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Copy" Command="Copy"/>
                            </ContextMenu>
                        </RichTextBox.ContextMenu>
                    </RichTextBox>
                </Grid>
            </TabItem>

            <!-- Console Tab -->
            <TabItem Header="Console">
                <Grid Margin="4">
                    <TextBox x:Name="ConsoleTextBox"
                             Text="{Binding ConsoleOutput, Mode=OneWay}"
                             IsReadOnly="True"
                             FontFamily="Consolas" FontSize="12"
                             VerticalScrollBarVisibility="Visible"
                             HorizontalScrollBarVisibility="Auto"
                             BorderThickness="0"
                             AcceptsReturn="True"
                             Padding="4"/>
                </Grid>
            </TabItem>

            <!-- Discord Tab -->
            <TabItem Header="Discord">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel>
                        <GroupBox Header="Discord Connection" Margin="0,0,0,8">
                            <StackPanel>
                                <Label Content="Bot Token:" Padding="0,0,0,2"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <PasswordBox x:Name="TokenBox" PasswordChar="•" VerticalContentAlignment="Center"
                                                 PasswordChanged="TokenBox_PasswordChanged"/>
                                    <Button Grid.Column="1" Content="Connect" Width="72" Margin="4,0,0,0"
                                            Command="{Binding ConnectDiscordCommand}" Padding="6,4"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Button Content="Disconnect" Width="72" Padding="6,4"
                                            Command="{Binding DisconnectDiscordCommand}"/>
                                    <TextBlock Text="{Binding BotStatus}" VerticalAlignment="Center" Margin="8,0,0,0"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Model Tab -->
            <TabItem Header="Model">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel>
                        <GroupBox Header="LLM (LlamaSharp)" Margin="0,0,0,8">
                            <StackPanel>
                                <Label Content="Model File:" Padding="0,0,0,2"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding ModelPath, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalContentAlignment="Center" IsReadOnly="True"
                                             TextWrapping="NoWrap" Padding="4,4"/>
                                    <Button Grid.Column="1" Content="Browse..." Width="64" Margin="4,0,0,0"
                                            Command="{Binding BrowseModelCommand}" Padding="6,4"/>
                                </Grid>

                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="Backend:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding ActiveBackend}" VerticalAlignment="Center"
                                               FontWeight="SemiBold"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Label Content="Mode:" Padding="0,0,4,0" VerticalAlignment="Center"/>
                                    <ComboBox ItemsSource="{Binding BackendModeOptions}"
                                              SelectedItem="{Binding BackendMode}"
                                              Width="110" VerticalContentAlignment="Center" Padding="4,4"/>
                                </StackPanel>

                                <Expander Header="Advanced" IsExpanded="False" Margin="0,6,0,0">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <Label Content="GPU Layers:" Padding="0,0,4,0" VerticalAlignment="Center"/>
                                            <Slider Minimum="0" Maximum="99" Value="{Binding GpuLayerCount}"
                                                    Width="120" IsSnapToTickEnabled="True" TickFrequency="1"
                                                    VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding GpuLayerCount}" VerticalAlignment="Center"
                                                       Margin="6,0,0,0" Width="24" TextAlignment="Right"/>
                                        </StackPanel>

                                        <CheckBox Content="Flash Attention" IsChecked="{Binding FlashAttention}"
                                                  Margin="0,2,0,0"/>

                                        <CheckBox Content="Auto Context Size" IsChecked="{Binding AutoContextSize}"
                                                  Margin="0,6,0,0"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                                    IsEnabled="{Binding IsManualContext}">
                                            <Label Content="Context:" Padding="0,0,4,0" VerticalAlignment="Center"/>
                                            <ComboBox ItemsSource="{Binding ContextSizeOptions}"
                                                      Text="{Binding ContextSizeText, UpdateSourceTrigger=PropertyChanged}"
                                                      IsEditable="True" Width="80"
                                                      VerticalContentAlignment="Center" Padding="4,4"/>
                                            <Label Content="tokens" Padding="4,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <Label Content="Temperature:" Padding="0,0,4,0" VerticalAlignment="Center"/>
                                            <Slider Minimum="0.1" Maximum="2.0" Value="{Binding Temperature}"
                                                    Width="120" IsSnapToTickEnabled="True" TickFrequency="0.1"
                                                    VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding TemperatureText}" VerticalAlignment="Center"
                                                       Margin="6,0,0,0" Width="24" TextAlignment="Right"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Expander>

                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Button Content="Load Model" Width="80" Padding="6,4"
                                            Command="{Binding LoadModelCommand}"/>
                                    <Button Content="Unload" Width="60" Margin="4,0,0,0" Padding="6,4"
                                            Command="{Binding UnloadModelCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Download Model" Margin="0,0,0,8">
                            <StackPanel>
                                <ComboBox ItemsSource="{Binding CuratedModelNames}"
                                          SelectedItem="{Binding SelectedCuratedModel}"
                                          VerticalContentAlignment="Center" Padding="4,4"/>
                                <Label Content="Or enter URL:" Padding="0,4,0,2"/>
                                <TextBox Text="{Binding CustomDownloadUrl, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalContentAlignment="Center" Padding="4,4"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ProgressBar Value="{Binding DownloadProgress}" Minimum="0" Maximum="100"
                                                 Height="20" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="4,0,0,0">
                                        <Button Content="Download" Width="72" Padding="6,4"
                                                Command="{Binding DownloadModelCommand}"/>
                                        <Button Content="Cancel" Width="56" Margin="4,0,0,0" Padding="6,4"
                                                Command="{Binding CancelDownloadCommand}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Rules Tab -->
            <TabItem Header="Rules">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBox Text="{Binding CustomRules, UpdateSourceTrigger=PropertyChanged}"
                             Grid.Row="0"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas" FontSize="12"
                             Padding="4"/>
                    <Button Content="Reset to Default" HorizontalAlignment="Right"
                            Grid.Row="1" Margin="0,4,0,0" Padding="6,4"
                            Command="{Binding ResetRulesCommand}"/>
                </Grid>
            </TabItem>

            <!-- RAG Tab -->
            <TabItem Header="RAG">
                <TabControl Margin="4">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Padding" Value="8,4"/>
                            <Setter Property="FontSize" Value="12"/>
                        </Style>
                    </TabControl.Resources>

                    <!-- Information Sub-Tab -->
                    <TabItem Header="Information">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20">
                                <Bold>Retrieval-Augmented Generation (RAG)</Bold> allows the bot to answer questions about your server by searching through provided documents, rather than feeding the entire document to the model.

                                <LineBreak/><LineBreak/><Bold>How it works:</Bold>
                                <LineBreak/>   1. Documents (wiki pages, rules, guides) are split into small paragraphs
                                <LineBreak/>   2. An embedding model converts each paragraph into a mathematical vector
                                <LineBreak/>   3. Vectors are stored in memory for fast retrieval
                                <LineBreak/>   4. When a question is asked, the database finds the 3-4 most relevant paragraphs
                                <LineBreak/>   5. Only those relevant paragraphs are sent to the main LLM to generate the answer

                                <LineBreak/><LineBreak/><Bold>Benefits:</Bold>
                                <LineBreak/>   • Faster responses — processing 500 tokens vs. 50,000+
                                <LineBreak/>   • Lower VRAM usage — no need to fit your entire wiki in context
                                <LineBreak/>   • Higher accuracy — the model focuses only on relevant information
                                <LineBreak/>   • Cost effective — an 8B model on an 8GB GPU works comfortably

                                <LineBreak/><LineBreak/><Bold>Models needed:</Bold>
                                <LineBreak/>   • <Bold>Chat Model:</Bold> Your main LLM (loaded in the Model tab) — generates the final answer
                                <LineBreak/>   • <Bold>Embedding Model:</Bold> A tiny model (~23MB) that converts text to searchable vectors

                                <LineBreak/><LineBreak/><Bold>Getting Started:</Bold>
                                <LineBreak/>   1. Go to the Embedding Model tab and download a small embedding model
                                <LineBreak/>   2. Go to the Documents tab and add your text/markdown/PDF files
                                <LineBreak/>   3. Click "Initialize RAG" to build the search engine
                                <LineBreak/>   4. Click "Ingest" to process documents into the vector database
                                <LineBreak/>   5. Test questions in the Test Query tab
                            </TextBlock>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Embedding Model Sub-Tab -->
                    <TabItem Header="Embedding Model">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                            <StackPanel>
                                <TextBlock Text="This tiny model converts text into searchable vectors. Use a small model like all-MiniLM-L6-v2 (Q4_K_M, ~23MB). Larger embedding models offer marginal accuracy gains and are not recommended."
                                           TextWrapping="Wrap" Margin="0,0,0,8" FontSize="11" Foreground="Gray"/>

                                <GroupBox Header="Embedding Model" Margin="0,0,0,8">
                                    <StackPanel>
                                        <Label Content="Model File:" Padding="0,0,0,2"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding RagEmbeddingModelPath, UpdateSourceTrigger=PropertyChanged}"
                                                     VerticalContentAlignment="Center" IsReadOnly="True"
                                                     TextWrapping="NoWrap" Padding="4,4"/>
                                            <Button Grid.Column="1" Content="Browse..." Width="64" Margin="4,0,0,0"
                                                    Command="{Binding BrowseRagEmbeddingModelCommand}" Padding="6,4"/>
                                        </Grid>
                                    </StackPanel>
                                </GroupBox>

                                <GroupBox Header="Download Embedding Model" Margin="0,0,0,8">
                                    <StackPanel>
                                        <ComboBox ItemsSource="{Binding CuratedModelNames}"
                                                  SelectedItem="{Binding SelectedCuratedModel}"
                                                  VerticalContentAlignment="Center" Padding="4,4"/>
                                        <Label Content="Or enter URL:" Padding="0,4,0,2"/>
                                        <TextBox Text="{Binding CustomDownloadUrl, UpdateSourceTrigger=PropertyChanged}"
                                                 VerticalContentAlignment="Center" Padding="4,4"/>
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ProgressBar Value="{Binding DownloadProgress}" Minimum="0" Maximum="100"
                                                         Height="20" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="4,0,0,0">
                                                <Button Content="Download" Width="72" Padding="6,4"
                                                        Command="{Binding DownloadModelCommand}"/>
                                                <Button Content="Cancel" Width="56" Margin="4,0,0,0" Padding="6,4"
                                                        Command="{Binding CancelDownloadCommand}"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </GroupBox>

                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Label Content="Context:" Padding="0,0,4,0" VerticalAlignment="Center"/>
                                    <ComboBox ItemsSource="{Binding ContextSizeOptions}"
                                              Text="{Binding RagContextSizeText, UpdateSourceTrigger=PropertyChanged}"
                                              IsEditable="True" Width="80"
                                              VerticalContentAlignment="Center" Padding="4,4"/>
                                    <Label Content="tokens" Padding="4,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Label Content="GPU Layers:" Padding="0,0,4,0" VerticalAlignment="Center"/>
                                    <Slider Minimum="0" Maximum="99" Value="{Binding RagGpuLayerCount}"
                                            Width="120" IsSnapToTickEnabled="True" TickFrequency="1"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding RagGpuLayerCount}" VerticalAlignment="Center"
                                               Margin="6,0,0,0" Width="24" TextAlignment="Right"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Button Content="Initialize RAG" Width="100" Padding="6,4"
                                            Command="{Binding InitializeRagCommand}"/>
                                    <TextBlock Text="{Binding RagStatusText}"
                                               VerticalAlignment="Center" Margin="12,0,0,0" FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Documents Sub-Tab -->
                    <TabItem Header="Documents">
                        <Grid Margin="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Add .txt, .md, or .pdf files containing server rules, guides, FAQs, or wiki pages."
                                       TextWrapping="Wrap" Margin="0,0,0,4" FontSize="11" Foreground="Gray" Grid.Row="0"/>

                            <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,4">
                                <Button Content="Add..." Width="60" Padding="4,4"
                                        Command="{Binding AddRagDocumentCommand}"/>
                                <Button Content="Remove" Width="60" Margin="4,0,0,0" Padding="4,4"
                                        Command="{Binding RemoveRagDocumentCommand}"
                                        CommandParameter="{Binding SelectedItem, ElementName=RagDocumentsListBox}"/>
                            </StackPanel>

                            <ListBox Grid.Row="2" x:Name="RagDocumentsListBox"
                                     ItemsSource="{Binding RagDocumentPaths}"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto" Margin="0,0,0,4"/>

                            <Grid Grid.Row="3" Margin="0,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ProgressBar Value="{Binding IngestProgress}" Minimum="0" Maximum="100"
                                             Height="20" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="Ingest" Width="72" Margin="4,0,0,0" Padding="6,4"
                                        Command="{Binding IngestDocumentsCommand}"/>
                            </Grid>

                            <TextBlock Grid.Row="4" Text="{Binding RagDocumentCount, StringFormat='Documents ingested: {0}'}"
                                       FontWeight="SemiBold" Margin="0,4,0,0"/>
                        </Grid>
                    </TabItem>

                    <!-- Test Query Sub-Tab -->
                    <TabItem Header="Test Query">
                        <Grid Margin="4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Ask a test question:" Margin="0,0,0,4" FontWeight="SemiBold" Grid.Row="0"/>
                            <Grid Grid.Row="1" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding RagQuestion, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalContentAlignment="Center" Padding="4,4"/>
                                <Button Grid.Column="1" Content="Ask" Width="56" Margin="4,0,0,0" Padding="6,4"
                                        Command="{Binding AskRagCommand}"/>
                            </Grid>

                            <TextBox Grid.Row="2" Text="{Binding RagAnswer, Mode=OneWay}"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     IsReadOnly="True"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas" FontSize="12"
                                     Padding="4" Margin="0,0,0,4"/>

                            <TextBlock Grid.Row="3" Text="Sources:" FontWeight="SemiBold" Margin="0,4,0,2"/>
                            <TextBox Grid.Row="4" Text="{Binding RagSources, Mode=OneWay}"
                                     IsReadOnly="True"
                                     VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas" FontSize="11"
                                     Padding="4" MinLines="3" MaxLines="6"/>
                        </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>

            <!-- Monitoring Tab -->
            <TabItem Header="Monitoring">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel>
                        <GroupBox Header="Channels to Monitor" Margin="0,0,0,8">
                            <StackPanel>
                                <Button Content="Refresh" HorizontalAlignment="Right" Padding="8,4"
                                        Command="{Binding RefreshChannelsCommand}" Margin="0,0,0,4"/>
                                <ListBox ItemsSource="{Binding Channels}" MaxHeight="160"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding DisplayText}" IsChecked="{Binding IsSelected}"
                                                      VerticalContentAlignment="Center" Margin="2,1"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Report Channel" Margin="0,0,0,8">
                            <ComboBox ItemsSource="{Binding Channels}"
                                      SelectedItem="{Binding SelectedReportChannel}"
                                      DisplayMemberPath="DisplayText"
                                      VerticalContentAlignment="Center" Padding="4,4"/>
                        </GroupBox>

                        <GroupBox Header="DM Reports To" Margin="0,0,0,8">
                            <ComboBox ItemsSource="{Binding Members}"
                                      Text="{Binding ReportDmUserText, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedItem="{Binding SelectedReportDmUser}"
                                      DisplayMemberPath="DisplayText"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      VerticalContentAlignment="Center" Padding="4,4"/>
                        </GroupBox>

                        <GroupBox Header="Report Types" Margin="0,0,0,8">
                            <StackPanel>
                                <CheckBox Content="Toxic Chat / Behavior" IsChecked="{Binding ReportToxicChat}"
                                          Margin="0,1"/>
                                <CheckBox Content="Complaints" IsChecked="{Binding ReportComplaints}" Margin="0,1"/>
                                <CheckBox Content="Server Issues" IsChecked="{Binding ReportServerIssues}" Margin="0,1"/>
                                <CheckBox Content="Server Down" IsChecked="{Binding ReportServerDown}" Margin="0,1"/>
                                <CheckBox Content="SimSpeed Issues" IsChecked="{Binding ReportSimSpeedIssues}" Margin="0,1"/>
                                <CheckBox Content="Player Complaints" IsChecked="{Binding ReportPlayerComplaints}" Margin="0,1"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Monitoring Controls" Margin="0,0,0,8">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Label Content="Interval:" Padding="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding IntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                                             Width="50" VerticalContentAlignment="Center" TextAlignment="Center"
                                             Padding="4,4"/>
                                    <Label Content="seconds" Padding="4,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Label Content="Window:" Padding="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding WindowSize, UpdateSourceTrigger=PropertyChanged}"
                                             Width="50" VerticalContentAlignment="Center" TextAlignment="Center"
                                             Padding="4,4"/>
                                    <Label Content="messages per channel" Padding="4,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock Text="{Binding BufferStats}" Margin="0,4,0,0" FontWeight="SemiBold"/>

                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Button Content="▶ Start" Width="72" Padding="6,4"
                                            Command="{Binding StartMonitoringCommand}"/>
                                    <Button Content="■ Stop" Width="56" Margin="4,0,0,0" Padding="6,4"
                                            Command="{Binding StopMonitoringCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <StatusBar Grid.Row="1" Padding="8,2">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <StatusBarItem Grid.Column="0" Margin="0,0,12,0">
                <TextBlock Text="{Binding BotStatus}"/>
            </StatusBarItem>
            <Separator Grid.Column="1" Margin="0,2,12,2" Style="{StaticResource {x:Static StatusBar.SeparatorStyleKey}}"/>
            <StatusBarItem Grid.Column="2" Margin="0,0,12,0">
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <StatusBarItem Grid.Column="3" HorizontalAlignment="Right">
                <TextBlock Text="{Binding BufferStats}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
